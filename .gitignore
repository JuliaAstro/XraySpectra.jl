deps/build.log
deps/downloads/
deps/usr/
deps/src/

# Build artifacts generated by Documenter
docs/build/
docs/site/

# Package-local resolution state. Commit for applications, not libraries.
Manifest.toml

# Local editor and OS files
.vscode/
.DS_Store
